{
    "name": "Node.js & TypeScript",
    "build": {
        "dockerfile": "base.Dockerfile",
        // Update 'VARIANT' to pick a Node version: 18, 16, 14.
        // Append -bullseye or -buster to pin to an OS version.
        // Use -bullseye variants on local on arm64/Apple Silicon.
        "args": {
            "VARIANT": "latest"
        },
        "context": ".."
    },
    // Configure tool-specific properties.
    "customizations": {
        // Configure properties specific to VS Code.
        "vscode": {
            // Add the IDs of extensions you want installed when the container is created.
            "extensions": [
                "dbaeumer.vscode-eslint",
                "esbenp.prettier-vscode",
                "christian-kohler.path-intellisense",
                "dzhavat.bracket-pair-toggler",
                "eamodio.gitlens",
                "xabikos.ReactSnippets",
                "christian-kohler.npm-intellisense",
                "ms-vscode.vscode-typescript-next",
                "ms-azuretools.azure-dev"
            ]
        }
    },
    // Use 'forwardPorts' to make a list of ports inside the container available locally.
    // "forwardPorts": [],
    // Mount node_modules and pnpm store on container-managed volumes.
    // This avoids file-operation issues on Windows-mounted workspaces (9p/DrvFS)
    // and makes installs much faster.
    "mounts": [
        "type=volume,source=contentprocessorweb-node_modules,target=/workspaces/ContentProcessorWeb/node_modules",
        "type=volume,source=contentprocessorweb-pnpm-store,target=/home/node/.pnpm-store"
    ],
    // Use 'postCreateCommand' to run commands after the container is created.
    // The mounted volumes can come in as root-owned on some hosts, so fix permissions first.
    "postCreateCommand": "sudo mkdir -p /home/node/.pnpm-store /workspaces/ContentProcessorWeb/node_modules && sudo chown -R node:node /home/node/.pnpm-store /workspaces/ContentProcessorWeb/node_modules && pnpm install",
    // Comment out to connect as root instead. More info: https://aka.ms/vscode-remote/containers/non-root.
    "remoteUser": "node"
}